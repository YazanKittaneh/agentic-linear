{
  "name": "agentic-linear",
  "version": "0.1.0",
  "description": "Reusable service that connects Linear tickets to AI agents that implement fixes and features",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "agentic-linear": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "lint": "eslint src/**/*.ts",
    "format": "prettier --write src/**/*.ts"
  },
  "keywords": [
    "linear",
    "agentic",
    "ai",
    "automation",
    "github"
  ],
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "inquirer": "^9.2.20",
    "simple-git": "^3.25.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/inquirer": "^9.0.7",
    "@types/node": "^22.0.0",
    "tsx": "^4.15.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
